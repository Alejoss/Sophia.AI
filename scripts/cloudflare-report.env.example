# Cloudflare analytics report script
# Copy relevant lines to acbc_app/.env or project root .env (both are read by the script).

# API token: Account Analytics:Read + Zone Analytics:Read (+ Zone:Read if using CF_ZONE_NAME)
# Create at https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=

# Account ID (Manage Account → right sidebar)
CF_ACCOUNT_ID=

# Zone ID (optional if CF_ZONE_NAME is set)
CF_ZONE_ID=

# Default zone name when CF_ZONE_ID is empty
CF_ZONE_NAME=academiablockchain.com

# Lookback window for reports
CF_REPORT_DAYS=7

# Output directory (default: <repo>/reports/cloudflare)
# CF_REPORT_OUTPUT_DIR=./reports/cloudflare

# --- GitHub Actions (repository secrets, same names) ---
# Settings → Secrets and variables → Actions
# CF_API_TOKEN, CF_ACCOUNT_ID, CF_ZONE_NAME (or CF_ZONE_ID)
# NOTION_TOKEN, NOTION_DATABASE_ID (for alerts when something needs attention)

# --- Notion alerts (optional locally; required in GHA for --notify-notion) ---
# Create an integration at https://www.notion.so/my-integrations
# Share your target database with that integration (⋯ → Connections).
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Property names must match your Notion database schema.
# Leave a NOTION_PROP_* empty to skip that property.
# NOTION_PROP_TITLE=Name
# NOTION_PROP_DESCRIPTION=Description
# NOTION_PROP_SEVERITY=Priority
# NOTION_PROP_STATUS=Status
# NOTION_PROP_SOURCE=Source
# NOTION_PROP_CATEGORY=Category
# NOTION_STATUS_VALUE=To do
# NOTION_SOURCE_VALUE=Cloudflare Analytics

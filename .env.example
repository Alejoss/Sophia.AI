# Docker Compose — image registry only (project root, next to docker-compose.prod.yml)
# Copy to .env if you need overrides for deploy.sh / docker compose substitution.
#
# Database credentials belong in acbc_app/.env only (loaded via env_file).
# Do NOT put POSTGRES_PASSWORD or DB_PASSWORD here: Docker Compose auto-loads this
# file and treats $ in values as variable references (e.g. WARN "vL8" is not set).

# GHCR image prefix (deploy.sh auto-detects from git remote if unset)
# GHCR_IMAGE_PREFIX=ghcr.io/owner/repo

# Image tag to deploy (default: main)
# IMAGE_TAG=main

# API Configuration
# Backend API URL
# Development: http://localhost:8000/api
# Production: https://sophia-ai-api.algobeat.com/api
VITE_API_URL=http://localhost:8000/api

# Google OAuth Configuration (Optional)
# Required for social login functionality
# Get credentials from: https://console.cloud.google.com/
# Make sure to add http://localhost:5173 to authorized redirect URIs
VITE_GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id

# Environment
# Automatically set by Vite, but can be overridden
# NODE_ENV=development

# Sentry (optional) – frontend error tracking for beta/production
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Google Analytics 4 (optional) – only loads when set
# Get Measurement ID from: https://analytics.google.com/ (Admin → Data streams)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel (optional) – required to enable PageView / Lead tracking
# VITE_META_PIXEL_ID=your-meta-pixel-id
